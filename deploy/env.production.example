NODE_ENV=production
HOST=127.0.0.1
PORT=3000
APP_BASE_URL=https://example.com
TRUST_PROXY=true
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://example.com/google/callback

OUTIL_PME_STORAGE_DIR=/var/lib/outil-pme/storage
OUTIL_PME_DATA_DIR=/var/lib/outil-pme/storage/data
OUTIL_PME_DB_PATH=/var/lib/outil-pme/storage/data/app.db
OUTIL_PME_CLIENTS_DIR=/var/lib/outil-pme/storage/clients
OUTIL_PME_ATTACHMENTS_DIR=/var/lib/outil-pme/storage/client_orders_files
OUTIL_PME_QUOTE_PHOTO_DIR=/var/lib/outil-pme/storage/quote_photos
OUTIL_PME_MEASUREMENT_PHOTO_DIR=/var/lib/outil-pme/storage/measurement_photos
OUTIL_PME_PDF_DIR=/var/lib/outil-pme/storage/pdf

DB_CLIENT=sqlite

DATABASE_URL=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=outil_pme
POSTGRES_USER=outil_pme
POSTGRES_PASSWORD=
POSTGRES_SSL=false
