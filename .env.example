# Variables Google OAuth (exemples uniquement)
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
APP_BASE_URL=http://localhost:3000
TRUST_PROXY=false
SESSION_SECRET=change-me
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/google/callback

# Stockage multiplateforme
# Par défaut, l'application utilise ./storage
# Exemple Linux VPS : /var/lib/outil-pme
OUTIL_PME_STORAGE_DIR=./storage
OUTIL_PME_DATA_DIR=./storage/data
OUTIL_PME_DB_PATH=./storage/data/app.db
OUTIL_PME_CLIENTS_DIR=./storage/clients
OUTIL_PME_ATTACHMENTS_DIR=./storage/client_orders_files
OUTIL_PME_QUOTE_PHOTO_DIR=./storage/quote_photos
OUTIL_PME_MEASUREMENT_PHOTO_DIR=./storage/measurement_photos
OUTIL_PME_PDF_DIR=./storage/pdf

# Base de données
# SQLite reste le moteur actif par défaut.
DB_CLIENT=sqlite

# Préparation PostgreSQL future, non activée tant que DB_CLIENT reste sqlite.
DATABASE_URL=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=outil_pme
POSTGRES_USER=outil_pme
POSTGRES_PASSWORD=
POSTGRES_SSL=false
